#ShadowRun_Green, by ARSLONGA. Based on Orblack_slim (by frigKx) and arch.blue (by dimaka)

# Window title justification
window.label.text.justify: right

# Window geometry
padding.width: 1
border.width: 2
window.client.padding.width: 0
window.client.padding.height: 2
window.handle.width: 0
osd.border.width: 2

# Menu geometry
menu.border.width: 3
menu.overlap: 0

# OSD
!! On-screen displays
osd.bg: gradient vertical flat
osd.bg.color: #2B2B2B
osd.bg.colorTo: #1d1d1d
osd.label.text.color: #ffffff

# Border colors
window.active.border.color: #2B2B2B
window.inactive.border.color: #2B2B2B
menu.border.color: #67A429
window.active.client.color: #67A429
window.inactive.client.color: #E04613
osd.border.color: #67A429

# Text shadows
window.active.label.text.font: shadow=n
window.inactive.label.text.font: shadow=n
menu.items.font: shadow=n
menu.title.text.font: shadow=n

#Menu
menu.items.active.bg: solid flat
menu.items.active.bg.color: #1d1d1d
menu.items.active.text.color: #E04613

menu.title.bg: raised splitvertical gradient
menu.title.bg.color: #202020
menu.title.bg.colorTo: #181818
menu.title.text.color: #ffffff
menu.title.text.justify: center

menu.items.bg: flat solid gradient vertical
menu.items.bg.color: #000000
menu.items.bg.colorTo: #000000
menu.items.text.color: #c0c0c0
menu.items.justify: left
menu.items.disabled.text.color: #666666

# Active window
window.active.title.bg: Flat Gradient Vertical
window.active.title.bg.color: #2B2B2B
window.active.title.bg.colorTo: #1d1d1d
window.active.label.bg: Parentrelative
window.active.label.text.color: #ffffff

window.active.handle.bg: Flat Gradient Vertical
window.active.handle.bg.color: #f4f4f4
window.active.handle.bg.colorTo: #f4f4f4

window.active.grip.bg: Flat Gradient Vertical
window.active.grip.bg.color: #f4f4f4
window.active.grip.bg.colorTo: #f4f4f4

window.active.button.unpressed.bg: Flat Gradient Vertical
window.active.button.unpressed.bg.color: #2B2B2B
window.active.button.unpressed.bg.colorTo: #1d1d1d
window.active.button.unpressed.image.color: #67A429

window.active.button.pressed.bg: Flat Gradient Vertical Border
window.active.button.pressed.bg.color: #2B2B2B
window.active.button.pressed.bg.colorTo: #1d1d1d
window.active.button.pressed.bg.border.color: #E04613
window.active.button.pressed.image.color: #ffffff

window.active.button.disabled.bg: Flat Gradient Vertical
window.active.button.disabled.bg.color: #2B2B2B
window.active.button.disabled.bg.colorTo: #1d1d1d
window.active.button.disabled.image.color: #67A429

window.active.button.toggled.bg: Flat Gradient Vertical
window.active.button.toggled.bg.color: #1d1d1d
window.active.button.toggled.bg.colorTo: #2B2B2B
window.active.button.toggled.image.color: #ffffff

window.active.button.hover.bg: Flat Gradient Vertical
window.active.button.hover.bg.color: #2B2B2B
window.active.button.hover.bg.colorTo: #1d1d1d
window.active.button.hover.image.color: #E04613

# Inactive windows
window.inactive.title.bg: Flat Gradient Vertical
window.inactive.title.bg.color: #1d1d1d
window.inactive.title.bg.colorTo: #2B2B2B

window.inactive.label.bg: Parentrelative
window.inactive.label.text.color: #c0c0c0

window.inactive.handle.bg: Flat Gradient Vertical
window.inactive.handle.bg.color: #f4f4f4
window.inactive.handle.bg.colorTo: #f4f4f4

window.inactive.grip.bg: Flat Gradient Vertical
window.inactive.grip.bg.color: #f4f4f4
window.inactive.grip.bg.colorTo: #f4f4f4

window.inactive.button.unpressed.bg: Flat Gradient Vertical
window.inactive.button.unpressed.bg.color: #1d1d1d
window.inactive.button.unpressed.bg.colorTo: #2B2B2B
window.inactive.button.unpressed.image.color: #E04613

window.inactive.button.pressed.bg: Flat Gradient Vertical
window.inactive.button.pressed.bg.color: #2B2B2B
window.inactive.button.pressed.bg.colorTo: #1d1d1d
window.inactive.button.pressed.image.color: #E04613

window.inactive.button.disabled.bg: Flat Gradient Vertical
window.inactive.button.disabled.bg.color: #2B2B2B
window.inactive.button.disabled.bg.colorTo: #1d1d1d
window.inactive.button.disabled.image.color: #E04613

window.inactive.button.toggled.bg: Flat Gradient Vertical
window.inactive.button.toggled.bg.color: #1d1d1d
window.inactive.button.toggled.bg.colorTo: #2B2B2B
window.inactive.button.toggled.image.color: #ffffff

window.inactive.button.hover.bg: Flat Gradient Vertical
