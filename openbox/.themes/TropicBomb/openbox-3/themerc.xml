        <pressed>
          <style>flat vertical gradient</style>
          <primary r="202" g="202" b="202" a="255"/>
          <secondary r="255" g="255" b="255" a="255"/>
        </pressed>
      </buttons>
      <titlebar>
        <style>flat</style>
        <primary r="66" g="66" b="66" a="255"/>
      </titlebar>
      <handle>
        <style>flat</style>
        <primary r="255" g="255" b="255" a="255"/>
      </handle>
      <grip>
        <style>flat</style>
        <primary r="243" g="243" b="243" a="255"/>
      </grip>
    </inactive>
    <justify>left</justify>
  </window>
  <menu>
    <border r="0" g="0" b="0" a="255"/>
    <justify>left</justify>
    <title>
      <text>
        <primary r="255" g="255" b="255" a="255"/>
        <shadow>
          <offset x="1" y="1"/>
        </shadow>
      </text>
      <style>flat</style>
      <primary r="66" g="66" b="66" a="255"/>
    </title>
    <inactive>
      <primary r="129" g="128" b="124" a="255"/>
    </inactive>
    <disabled>
      <primary r="215" g="215" b="215" a="255"/>
    </disabled>
    <activedisabled>
      <text>
        <primary r="215" g="215" b="215" a="255"/>
      </text>
      <style>flat border</style>
      <primary r="241" g="241" b="241" a="255"/>
      <border r="219" g="219" b="219" a="255"/>
    </activedisabled>
    <active>
      <text>
        <primary r="0" g="0" b="0" a="255"/>
      </text>
      <style>flat border</style>
      <primary r="241" g="241" b="241" a="255"/>
      <border r="219" g="219" b="219" a="255"/>
